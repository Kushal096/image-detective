# ── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ── Game ───────────────────────────────────────────────
DEFAULT_ROUND_SECONDS=60
MAX_PLAYERS_PER_ROOM=100
ROOM_IDLE_TIMEOUT_MS=1800000

# ── AI / Worker Pool ───────────────────────────────────
AI_MODEL=Xenova/clip-vit-base-patch32
AI_WORKER_CONCURRENCY=2
# When true, skips real CLIP inference and uses a deterministic mock score.
# Useful for local dev / CI when the model cannot be downloaded.
AI_MOCK=false

# ── Uploads ────────────────────────────────────────────
MAX_UPLOAD_BYTES=8388608

# ── Firebase (optional) ────────────────────────────────
# Leave empty to run with in-memory persistence (no Firestore).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
